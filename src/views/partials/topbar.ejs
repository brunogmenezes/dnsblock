<header class="topbar-modern">
  <div class="topbar-left">
    <h1><%= typeof pageTitle !== 'undefined' ? pageTitle : 'DNSBlock' %></h1>
    <% if (typeof pageSubtitle !== 'undefined' && pageSubtitle) { %>
      <p class="subtitle-modern"><%= pageSubtitle %></p>
    <% } %>
  </div>
  <div class="topbar-right">
    <details class="user-dropdown">
      <summary class="user-dropdown-trigger">
        <div class="user-avatar">
          <%= user && user.username ? user.username.charAt(0).toUpperCase() : 'U' %>
        </div>
        <span class="user-dropdown-text"><%= user ? user.username : 'Usuário' %></span>
        <span class="user-dropdown-caret" aria-hidden="true">▾</span>
      </summary>
      <div class="user-dropdown-menu">
        <div class="user-dropdown-header">
          <strong><%= user ? user.full_name : 'Usuário' %></strong>
          <span>@<%= user ? user.username : '' %></span>
        </div>
        <hr class="dropdown-divider" />
        <a href="/account/password" class="user-dropdown-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          Trocar minha senha
        </a>
        <form method="post" action="/logout" class="user-dropdown-form">
          <button type="submit" class="user-dropdown-logout">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
            Sair do sistema
          </button>
        </form>
      </div>
    </details>
  </div>
</header>

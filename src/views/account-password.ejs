<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/public/css/styles.css" />
  </head>
  <body class="app-layout bg-grid">
    <%- include('partials/sidebar', { activePage: '' }) %>
    <div class="main-content">
      <%- include('partials/topbar', { pageTitle: 'Alterar Minha Senha', pageSubtitle: forceChange ? 'A troca da senha é obrigatória antes de acessar o restante do sistema.' : 'Atualize sua senha pessoal sempre que precisar.' }) %>

      <main class="content-wrap narrow-wrap">
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <% if (forceChange) { %>
        <div class="alert alert-warning">Seu usuário foi criado com uma senha provisória. Informe a senha atual e defina uma nova senha para continuar.</div>
      <% } %>

      <section class="form-panel">
        <form method="post" action="/account/password" class="form-stack">
          <label for="currentPassword">Senha atual</label>
          <input id="currentPassword" name="currentPassword" type="password" required />

          <label for="newPassword">Nova senha</label>
          <input id="newPassword" name="newPassword" type="password" required />
          <p class="helper-text">Use pelo menos 6 caracteres.</p>

          <label for="confirmPassword">Confirmar nova senha</label>
          <input id="confirmPassword" name="confirmPassword" type="password" required />

          <button type="submit" class="btn-primary">Salvar nova senha</button>
        </form>
      </section>
    </main>

    <% if (toast && toast.text) { %>
      <script>
        (function () {
          const toast = document.getElementById('app-toast');
          const closeBtn = document.getElementById('toast-close');

          if (!toast) return;

          function closeToast() {
            toast.classList.add('toast-out');
            window.setTimeout(() => toast.remove(), 300);
          }

          if (closeBtn) {
            closeBtn.addEventListener('click', closeToast);
          }

          window.setTimeout(closeToast, 4500);
        })();
      </script>
    <% } %>
    </div> <!-- .main-content -->
  </body>
</html>

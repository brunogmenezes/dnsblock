<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/public/css/styles.css" />
  </head>
  <body class="app-layout bg-grid">
    <%- include('partials/sidebar', { activePage: 'users' }) %>
    <div class="main-content">
      <%- include('partials/topbar', { pageTitle: 'Usuários do Sistema', pageSubtitle: 'Cadastre acessos e defina a troca obrigatória de senha' }) %>

      <main class="content-wrap">

    <% const safeUsers = Array.isArray(users) ? users : []; %>
    <% const totalUsers = safeUsers.length; %>
    <% const totalAdmins = safeUsers.filter((u) => u.is_admin).length; %>
    <% const totalActive = safeUsers.filter((u) => u.is_active).length; %>
    <% const totalForceChange = safeUsers.filter((u) => u.must_change_password).length; %>


      <% if (error) { %>
        <div class="alert alert-error user-page-alert"><%= error %></div>
      <% } %>

      <section class="cards-grid user-page-alert">
        <article class="metric-card">
          <p>Total de Usuários</p>
          <h2><%= totalUsers %></h2>
        </article>
        <article class="metric-card">
          <p>Administradores</p>
          <h2><%= totalAdmins %></h2>
        </article>
        <article class="metric-card">
          <p>Usuários Ativos</p>
          <h2><%= totalActive %></h2>
        </article>
        <article class="metric-card">
          <p>Troca Obrigatória</p>
          <h2><%= totalForceChange %></h2>
        </article>
      </section>

      <div class="users-layout">
        <section class="form-panel user-create-panel">
          <div class="table-header">
          <h3>Novo usuário</h3>
        </div>
        <p class="helper-text user-form-lead">Preencha os dados de acesso e defina as permissões iniciais.</p>

        <form method="post" action="/users" class="form-stack user-form-grid" autocomplete="off">
          <input class="autofill-trap" type="text" name="fakeUsername" autocomplete="username" tabindex="-1" aria-hidden="true" />
          <input class="autofill-trap" type="password" name="fakePassword" autocomplete="current-password" tabindex="-1" aria-hidden="true" />

          <div class="user-field">
            <label for="fullName">Nome completo</label>
            <input id="fullName" name="fullName" type="text" placeholder="Ex.: João da Silva" value="<%= formData.fullName || '' %>" autocomplete="off" required />
          </div>

          <div class="user-field">
            <label for="username">Usuário</label>
            <input id="username" name="username" type="text" placeholder="Ex.: joao.silva" value="<%= formData.username || '' %>" autocomplete="off" autocapitalize="off" spellcheck="false" required />
          </div>

          <div class="user-form-grid-span user-field">
            <label for="password">Senha inicial</label>
            <input id="password" name="password" type="password" autocomplete="new-password" required />
            <p class="helper-text">Use essa senha para o primeiro acesso do usuário.</p>
          </div>

          <label class="check-row user-form-grid-span user-check-row">
            <input name="mustChangePassword" type="checkbox" <%= formData.mustChangePassword ? 'checked' : '' %> />
            <span>Obrigar troca de senha ao fazer login</span>
          </label>

          <label class="check-row user-form-grid-span user-check-row">
            <input name="isAdmin" type="checkbox" <%= formData.isAdmin ? 'checked' : '' %> />
            <span>Permitir gerenciar usuários (Admin Master)</span>
          </label>

          <div class="user-form-grid-span user-field">
            <label for="groupId">Grupo de Usuário (Perfil de Acesso)</label>
            <select id="groupId" name="groupId">
              <option value="">Sem grupo específico</option>
              <% groups.forEach(function(g) { %>
                <option value="<%= g.id %>" <%= formData.groupId == g.id ? 'selected' : '' %>><%= g.name %></option>
              <% }) %>
            </select>
            <p class="helper-text">O grupo define quais páginas e ações este usuário poderá acessar.</p>
          </div>

          <div class="user-form-grid-span user-submit-wrap">
            <button type="submit" class="btn-primary">Criar usuário</button>
          </div>
        </form>
      </section>

      <section class="table-section">
        <div class="table-header">
          <h3>Usuários cadastrados</h3>
        </div>

        <div class="table-controls" data-table-controls="users-table" style="display: flex; gap: 12px; align-items: flex-end;">
          <div style="flex: 1;">
            <label for="users-filter" style="margin-bottom: 4px;">Buscar usuário</label>
            <input id="users-filter" type="text" placeholder="Nome ou login..." />
          </div>
          <div>
            <label for="users-profile-filter" style="margin-bottom: 4px;">Perfil / Grupo</label>
            <select id="users-profile-filter">
              <option value="">Todos</option>
              <option value="admin">Administrador Master</option>
              <% groups.forEach(function(g) { %>
                <option value="group-<%= g.id %>"><%= g.name %></option>
              <% }) %>
              <option value="no-group">Sem Grupo</option>
            </select>
          </div>
          <div>
            <label for="users-page-size" style="margin-bottom: 4px;">Exibir</label>
            <select id="users-page-size">
              <option value="5">5</option>
              <option value="10" selected>10</option>
              <option value="20">20</option>
              <option value="50">50</option>
            </select>
          </div>
        </div>

        <div class="table-container">
          <table id="users-table">
            <thead>
              <tr>
                <th>Nome</th>
                <th>Usuário</th>
                <th>Grupo / Perfil</th>
                <th>Status</th>
                <th>Troca obrigatória</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              <% if (!users || users.length === 0) { %>
                <tr class="empty-row">
                  <td colspan="6">Nenhum usuário cadastrado.</td>
                </tr>
              <% } %>
              <% if (users && users.length > 0) { %>
                <% users.forEach(function (row) { %>
                  <tr
                    class="data-row"
                    data-name="<%= (row.full_name || '').toLowerCase() %>"
                    data-username="<%= (row.username || '').toLowerCase() %>"
                    data-profile="<%= row.is_admin ? 'admin' : (row.group_id ? 'group-' + row.group_id : 'no-group') %>"
                  >
                    <td><%= row.full_name %></td>
                    <td><%= row.username %></td>
                    <td>
                      <% if (row.is_admin) { %>
                        <span class="status-pill is-admin">Admin Master</span>
                      <% } else if (row.group_name) { %>
                        <span class="status-pill is-user"><%= row.group_name %></span>
                      <% } else { %>
                        <span class="status-pill is-inactive">Sem Grupo</span>
                      <% } %>
                    </td>
                    <td><span class="status-pill <%= row.is_active ? 'is-active' : 'is-inactive' %>"><%= row.is_active ? 'Ativo' : 'Inativo' %></span></td>
                    <td><%= row.must_change_password ? 'Sim' : 'Não' %></td>
                    <td>
                      <div class="user-actions-cell">
                        <a href="/users/<%= row.id %>/edit" class="btn-secondary user-action-btn">Editar</a>
                        <% if (row.id !== user.id) { %>
                          <button type="button" class="btn-danger user-action-btn btn-trigger-delete" data-id="<%= row.id %>" data-name="<%= row.full_name %>">Excluir</button>
                        <% } else { %>
                          <span class="helper-text">Você</span>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>

        <div class="table-pagination" data-pagination="users-table">
          <button type="button" id="users-prev" class="btn-secondary">Anterior</button>
          <span id="users-page-info">Página 1 de 1</span>
          <button type="button" id="users-next" class="btn-secondary">Próxima</button>
        </div>
      </section>
      </div>
    </main>

    <!-- Modal Confirmar Exclusão -->
    <div id="modal-confirm-delete" class="modal" style="display:none;position:fixed;z-index:4000;left:0;top:0;width:100vw;height:100vh;background:rgba(0,0,0,0.35);align-items:center;justify-content:center;">
      <div class="modal-content" style="background:#fff;padding:32px 24px;border-radius:12px;width:90%;max-width:400px;box-shadow:var(--shadow-lg);position:relative;animation:modalIn 0.3s ease;text-align:center;">
        <div style="color:var(--danger);margin-bottom:20px;display:flex;justify-content:center;">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
        </div>
        <h2 style="margin-top:0;margin-bottom:12px;font-size:1.3rem;font-weight:700;">Confirmar Exclusão</h2>
        <p style="color:var(--muted);margin-bottom:24px;line-height:1.5;">Deseja realmente excluir o usuário <strong id="delete-user-name"></strong>?</p>
        
        <div style="display:flex;gap:12px;justify-content:center;border-top:1px solid var(--line);padding-top:20px;">
          <button type="button" id="cancel-delete" class="btn-secondary" style="padding:10px 24px;cursor:pointer;">Cancelar</button>
          <form id="form-confirm-delete" method="post" action="">
            <button type="submit" class="btn-danger" style="padding:10px 24px;cursor:pointer;">Confirmar Exclusão</button>
          </form>
        </div>
      </div>
    </div>

    <script>
      (function () {
        const table = document.getElementById('users-table');
        if (!table) return;

        const tbody = table.querySelector('tbody');
        if (!tbody) return;

        const textFilter = document.getElementById('users-filter');
        const profileFilter = document.getElementById('users-profile-filter');
        const pageSizeSelect = document.getElementById('users-page-size');
        const prevBtn = document.getElementById('users-prev');
        const nextBtn = document.getElementById('users-next');
        const pageInfo = document.getElementById('users-page-info');

        const allRows = Array.from(tbody.querySelectorAll('tr.data-row'));
        const emptyRow = tbody.querySelector('tr.empty-row');

        let currentPage = 1;
        let pageSize = Number(pageSizeSelect ? pageSizeSelect.value : 10);

        function updateUsersTable() {
          const textTerm = (textFilter ? textFilter.value : '').trim().toLowerCase();
          const profileTerm = (profileFilter ? profileFilter.value : '').trim().toLowerCase();

          const matchedRows = allRows.filter((row) => {
            const name = row.getAttribute('data-name') || '';
            const username = row.getAttribute('data-username') || '';
            const profile = row.getAttribute('data-profile') || '';

            const matchesText = !textTerm || name.includes(textTerm) || username.includes(textTerm);
            const matchesProfile = !profileTerm || profile === profileTerm;

            return matchesText && matchesProfile;
          });

          const totalRows = matchedRows.length;
          const totalPages = Math.max(1, Math.ceil(totalRows / pageSize));
          if (currentPage > totalPages) currentPage = totalPages;

          const start = (currentPage - 1) * pageSize;
          const end = start + pageSize;
          const visibleRows = matchedRows.slice(start, end);

          allRows.forEach((row) => {
            row.style.display = visibleRows.includes(row) ? '' : 'none';
          });

          if (emptyRow) {
            emptyRow.style.display = totalRows === 0 ? '' : 'none';
          }

          if (pageInfo) {
            pageInfo.textContent = `Página ${currentPage} de ${totalPages} (${totalRows} registros)`;
          }

          if (prevBtn) prevBtn.disabled = currentPage <= 1;
          if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
        }

        if (textFilter) {
          textFilter.addEventListener('input', function () {
            currentPage = 1;
            updateUsersTable();
          });
        }

        if (profileFilter) {
          profileFilter.addEventListener('change', function () {
            currentPage = 1;
            updateUsersTable();
          });
        }

        if (pageSizeSelect) {
          pageSizeSelect.addEventListener('change', function () {
            pageSize = Number(pageSizeSelect.value) || 10;
            currentPage = 1;
            updateUsersTable();
          });
        }

        if (prevBtn) {
          prevBtn.addEventListener('click', function () {
            if (currentPage > 1) {
              currentPage -= 1;
              updateUsersTable();
            }
          });
        }

        if (nextBtn) {
          nextBtn.addEventListener('click', function () {
            currentPage += 1;
            updateUsersTable();
          });
        }

        updateUsersTable();

        // Lógica do Modal de Exclusão
        const modalDelete = document.getElementById('modal-confirm-delete');
        const deleteUserNameSpan = document.getElementById('delete-user-name');
        const formConfirmDelete = document.getElementById('form-confirm-delete');
        const cancelDeleteBtn = document.getElementById('cancel-delete');

        document.querySelectorAll('.btn-trigger-delete').forEach(btn => {
          btn.onclick = function() {
            const id = this.getAttribute('data-id');
            const name = this.getAttribute('data-name');
            deleteUserNameSpan.textContent = name;
            formConfirmDelete.action = `/users/${id}/delete`;
            modalDelete.style.display = 'flex';
          };
        });

        const hideDeleteModal = () => { modalDelete.style.display = 'none'; };
        if (cancelDeleteBtn) cancelDeleteBtn.onclick = hideDeleteModal;
        window.addEventListener('click', (e) => { if (e.target === modalDelete) hideDeleteModal(); });

      })();
    </script>

    <%- include('partials/toast') %>
    </div> <!-- .main-content -->
  </body>
</html>

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/public/css/styles.css" />
  </head>
  <body class="bg-grid">
    <% if (toast && toast.text) { %>
      <aside class="toast toast-<%= toast.type || 'info' %>" id="app-toast" role="status" aria-live="polite">
        <div class="toast-title"><%= toast.type === 'error' ? 'Falha na execução' : 'Notificação' %></div>
        <div class="toast-text"><%= toast.text %></div>
        <button type="button" class="toast-close" id="toast-close" aria-label="Fechar notificação">x</button>
        <div class="toast-bar"></div>
      </aside>
    <% } %>

    <header class="topbar">
      <div>
        <h1>DNSBlock</h1>
        <p>Olá, <strong><%= user.fullName || user.username %></strong></p>
      </div>
      <div class="topbar-actions">
        <a href="/dashboard" class="btn-secondary">Dashboard</a>
        <a href="/domains/new" class="btn-secondary">Cadastrar Domínios</a>
        <a href="/reports/nslookup" class="btn-secondary">Relatórios</a>
        <a href="/dns/integration" class="btn-secondary">Integração DNS</a>
        <% if (user.isAdmin) { %>
          <a href="/users" class="btn-secondary">Usuários</a>
        <% } %>
        <details class="user-dropdown">
          <summary class="user-dropdown-trigger">
            <span class="user-dropdown-text">@<%= user.username %></span>
            <span class="user-dropdown-caret" aria-hidden="true">▾</span>
          </summary>
          <div class="user-dropdown-menu">
            <a href="/account/password" class="user-dropdown-link">Trocar minha senha</a>
            <form method="post" action="/logout" class="user-dropdown-form">
              <button type="submit" class="user-dropdown-logout">Sair</button>
            </form>
          </div>
        </details>
      </div>
    </header>

    <main class="content-wrap">
      <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <section class="cards-grid">
        <article class="metric-card">
          <p>Total de Domínios</p>
          <h2><%= totals.total_count %></h2>
        </article>
        <article class="metric-card">
          <p>Com Ofício</p>
          <h2><%= totals.with_notice_count %></h2>
        </article>
        <article class="metric-card">
          <p>Sem Ofício</p>
          <h2><%= totals.without_notice_count %></h2>
        </article>
        <article class="metric-card">
          <p>Total de Ofícios</p>
          <h2><%= totals.total_notices %></h2>
        </article>
      </section>

      <section class="table-section">
        <div class="table-header">
          <h3>Exclusão de Domínios</h3>
        </div>
        <div class="delete-actions-grid">
          <form method="post" action="/domains/delete/by-domain" class="inline-form delete-form" data-confirm="Tem certeza que deseja excluir este domínio?" data-destructive="false">
            <label for="deleteDomainName">Excluir por nome de domínio</label>
            <div class="inline-form-row">
              <input id="deleteDomainName" name="domainName" type="text" placeholder="Ex.: bet.jogo.com" required />
              <button type="submit" class="btn-danger">Excluir domínio</button>
            </div>
          </form>

          <form method="post" action="/domains/delete/by-notice" class="inline-form delete-form" data-confirm="Tem certeza que deseja excluir todos os domínios deste ofício?" data-destructive="false">
            <label for="deleteNoticeCode">Excluir por número de ofício</label>
            <div class="inline-form-row">
              <input id="deleteNoticeCode" name="noticeCode" type="text" placeholder="Ex.: Ofício 123/2026" required />
              <button type="submit" class="btn-danger">Excluir por ofício</button>
            </div>
          </form>

          <form method="post" action="/domains/delete/all" class="inline-form delete-form" data-confirm="ATENCAO: isto vai excluir todos os dominios ativos da blocklist. Deseja continuar?" data-destructive="true">
            <label for="deleteAll">Excluir todos os domínios</label>
            <div class="inline-form-row">
              <button type="submit" class="btn-danger">Excluir todos</button>
            </div>
          </form>
        </div>
      </section>

      <section class="table-section">
        <div class="table-header">
          <h3>Domínios Bloqueados e Data da Execução</h3>
        </div>

        <div class="table-controls" data-table-controls="blocked-table">
          <input id="blocked-domain-filter" type="text" placeholder="Filtrar por domínio" />
          <input id="blocked-notice-filter" type="text" placeholder="Filtrar por número de ofício" />
          <select id="blocked-page-size" aria-label="Itens por página na tabela de bloqueados">
            <option value="5">5</option>
            <option value="10" selected>10</option>
            <option value="15">15</option>
            <option value="50">50</option>
            <option value="100">100</option>
          </select>
        </div>

        <div class="table-container">
          <table id="blocked-table">
            <thead>
              <tr>
                <th>Ofício</th>
                <th>Domínio</th>
                <th>Data da Execução</th>
                <th>Arquivo</th>
              </tr>
            </thead>
            <tbody>
              <% if (blockedGroups.length === 0) { %>
                <tr class="empty-row">
                  <td colspan="4">Nenhum domínio bloqueado cadastrado.</td>
                </tr>
              <% } %>
              <% blockedGroups.forEach(function (group, groupIndex) { %>
                <% const groupId = `blocked-group-${group.noticeId || 'none'}-${groupIndex}`; %>
                <tr class="group-row" data-group="<%= groupId %>" data-group-expanded="true">
                  <td colspan="4">
                    <button type="button" class="group-toggle-btn" data-group-id="<%= groupId %>" aria-expanded="true">
                      <span class="group-toggle-icon">▼</span>
                    </button>
                    <strong><%= group.noticeCode %></strong>
                    <span class="group-domain-count">(<%= group.domains.length %> domínio<%= group.domains.length !== 1 ? 's' : '' %>)</span>
                    <% if (group.fileName && group.noticeId) { %>
                      <a href="/notices/<%= group.noticeId %>/download" class="btn-link">Baixar Ofício</a>
                    <% } else { %>
                      <span class="muted-inline">Sem arquivo anexado</span>
                    <% } %>
                  </td>
                </tr>
                <% group.domains.forEach(function (row) { %>
                  <tr class="data-row" data-group="<%= groupId %>" data-domain="<%= row.domainName.toLowerCase() %>" data-notice="<%= (group.noticeCode || '').toLowerCase() %>">
                    <td><%= group.noticeCode %></td>
                    <td><%= row.domainName %></td>
                    <td><%= new Date(row.executedAt).toLocaleString('pt-BR') %></td>
                    <td>
                      <% if (group.fileName && group.noticeId) { %>
                        <a href="/notices/<%= group.noticeId %>/download" class="btn-link">Download</a>
                      <% } else { %>
                        -
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div class="table-pagination" data-pagination="blocked-table">
          <button type="button" id="blocked-prev" class="btn-secondary">Anterior</button>
          <span id="blocked-page-info">Página 1 de 1</span>
          <button type="button" id="blocked-next" class="btn-secondary">Próxima</button>
        </div>
      </section>
    </main>

    <% if (toast && toast.text) { %>
      <script>
        (function () {
          const toast = document.getElementById('app-toast');
          const closeBtn = document.getElementById('toast-close');

          if (!toast) return;

          function closeToast() {
            toast.classList.add('toast-out');
            window.setTimeout(() => toast.remove(), 300);
          }

          if (closeBtn) {
            closeBtn.addEventListener('click', closeToast);
          }

          window.setTimeout(closeToast, 4500);
        })();
      </script>
    <% } %>

    <script>
      (function () {
        // Setup group toggle functionality
        const table = document.getElementById('blocked-table');
        if (!table) return;

        const tbody = table.querySelector('tbody');
        const groupToggleBtns = tbody.querySelectorAll('.group-toggle-btn');
        const groupMap = {}; // Store expanded/collapsed state by group id

        // Initialize all groups as expanded
        groupToggleBtns.forEach((btn) => {
          const groupId = btn.getAttribute('data-group-id');
          groupMap[groupId] = true; // true = expanded
        });

        // Setup pagination variables that will be set by setupTable
        let currentPage = 1;
        let pageSize = 10;
        let updateTableFn = null;

        function setupTable(options) {
          const table = document.getElementById(options.tableId);
          if (!table) return;

          const tbody = table.querySelector('tbody');
          if (!tbody) return;

          const domainInput = document.getElementById(options.domainFilterId);
          const noticeInput = document.getElementById(options.noticeFilterId);
          const pageSizeSelect = document.getElementById(options.pageSizeId);
          const prevBtn = document.getElementById(options.prevBtnId);
          const nextBtn = document.getElementById(options.nextBtnId);
          const pageInfo = document.getElementById(options.pageInfoId);

          const allDataRows = Array.from(tbody.querySelectorAll('tr.data-row'));
          const allGroupRows = Array.from(tbody.querySelectorAll('tr.group-row'));
          const emptyRow = tbody.querySelector('tr.empty-row');

          currentPage = 1;
          pageSize = Number(pageSizeSelect ? pageSizeSelect.value : 10);

          updateTableFn = function() {
            const domainTerm = (domainInput ? domainInput.value : '').trim().toLowerCase();
            const noticeTerm = (noticeInput ? noticeInput.value : '').trim().toLowerCase();

            const matchedRows = allDataRows.filter((row) => {
              const domainValue = row.getAttribute('data-domain') || '';
              const noticeValue = row.getAttribute('data-notice') || '';

              const matchesDomain = !domainTerm || domainValue.includes(domainTerm);
              const matchesNotice = !noticeTerm || noticeValue.includes(noticeTerm);
              return matchesDomain && matchesNotice;
            });

            const totalRows = matchedRows.length;
            const totalPages = Math.max(1, Math.ceil(totalRows / pageSize));

            if (currentPage > totalPages) {
              currentPage = totalPages;
            }

            const start = (currentPage - 1) * pageSize;
            const end = start + pageSize;
            const visibleRows = matchedRows.slice(start, end);
            const visibleGroups = new Set(visibleRows.map((row) => row.getAttribute('data-group')));

            allGroupRows.forEach((row) => {
              row.style.display = visibleGroups.has(row.getAttribute('data-group')) ? '' : 'none';
            });

            allDataRows.forEach((row) => {
              const groupId = row.getAttribute('data-group');
              const isGroupExpanded = groupMap[groupId];
              const isRowVisible = visibleRows.includes(row);
              
              // Show/hide based on both visibility and expand state
              row.style.display = (isRowVisible && isGroupExpanded) ? '' : 'none';
            });

            if (emptyRow) {
              emptyRow.style.display = totalRows === 0 ? '' : 'none';
            }

            if (pageInfo) {
              pageInfo.textContent = `Página ${currentPage} de ${totalPages} (${totalRows} registros)`;
            }

            if (prevBtn) {
              prevBtn.disabled = currentPage <= 1;
            }

            if (nextBtn) {
              nextBtn.disabled = currentPage >= totalPages;
            }
          };

          if (domainInput) {
            domainInput.addEventListener('input', function () {
              currentPage = 1;
              updateTableFn();
            });
          }

          if (noticeInput) {
            noticeInput.addEventListener('input', function () {
              currentPage = 1;
              updateTableFn();
            });
          }

          if (pageSizeSelect) {
            pageSizeSelect.addEventListener('change', function () {
              pageSize = Number(pageSizeSelect.value) || 10;
              currentPage = 1;
              updateTableFn();
            });
          }

          if (prevBtn) {
            prevBtn.addEventListener('click', function () {
              if (currentPage > 1) {
                currentPage -= 1;
                updateTableFn();
              }
            });
          }

          if (nextBtn) {
            nextBtn.addEventListener('click', function () {
              currentPage += 1;
              updateTableFn();
            });
          }

          updateTableFn();
        }

        // Setup toggle button listeners AFTER setupTable is defined
        groupToggleBtns.forEach((btn) => {
          btn.addEventListener('click', function (e) {
            e.preventDefault();
            const groupId = btn.getAttribute('data-group-id');
            const isExpanded = groupMap[groupId];
            groupMap[groupId] = !isExpanded;

            // Update button state
            btn.setAttribute('aria-expanded', String(!isExpanded));
            const icon = btn.querySelector('.group-toggle-icon');
            if (icon) {
              icon.textContent = !isExpanded ? '▼' : '▶';
            }

            // Reaplicar a lógica de paginação após toggle
            if (updateTableFn) {
              updateTableFn();
            }
          });
        });

        setupTable({
          tableId: 'blocked-table',
          domainFilterId: 'blocked-domain-filter',
          noticeFilterId: 'blocked-notice-filter',
          pageSizeId: 'blocked-page-size',
          prevBtnId: 'blocked-prev',
          nextBtnId: 'blocked-next',
          pageInfoId: 'blocked-page-info',
        });
      })();
    </script>

    <script>
      // Delete form confirmation dialogs with custom modal
      (function () {
        let confirmModal = null;
        let confirmForm = null;

        function createConfirmModal() {
          const backdrop = document.createElement('div');
          backdrop.className = 'confirm-backdrop';
          backdrop.id = 'confirm-backdrop';

          backdrop.addEventListener('click', function (event) {
            if (event.target === backdrop) {
              closeModal();
            }
          });

          backdrop.innerHTML = `
            <div class="confirm-modal" id="confirm-modal">
              <h3 class="confirm-modal-title" id="confirm-title">Confirmação</h3>
              <p class="confirm-modal-body" id="confirm-message">Tem certeza?</p>
              <div class="confirm-modal-actions">
                <button type="button" class="btn-cancel" id="confirm-cancel">Cancelar</button>
                <button type="button" class="btn-confirm" id="confirm-ok">Confirmar</button>
              </div>
            </div>
          `;

          document.body.appendChild(backdrop);
          confirmModal = backdrop;

          document.getElementById('confirm-cancel').addEventListener('click', closeModal);
          document.getElementById('confirm-ok').addEventListener('click', function () {
            closeModal();
            if (confirmForm) {
              confirmForm.submit();
            }
          });
        }

        function closeModal() {
          if (confirmModal) {
            confirmModal.classList.add('out');
            setTimeout(function () {
              if (confirmModal) {
                document.body.removeChild(confirmModal);
                confirmModal = null;
              }
              confirmForm = null;
            }, 160);
          }
        }

        function showConfirmModal(message, form, isDestructive) {
          if (!confirmModal) {
            createConfirmModal();
          }

          confirmForm = form;
          document.getElementById('confirm-message').textContent = message;
          
          const btnConfirm = document.getElementById('confirm-ok');
          if (isDestructive) {
            btnConfirm.classList.remove('success');
          } else {
            btnConfirm.classList.add('success');
          }
        }

        document.addEventListener('keydown', function (event) {
          if (event.key === 'Escape') {
            closeModal();
          }
        });

        const confirmableForms = document.querySelectorAll('form[data-confirm]');
        confirmableForms.forEach((form) => {
          form.addEventListener('submit', function (event) {
            event.preventDefault();
            const confirmMessage = form.getAttribute('data-confirm');
            const isDestructive = form.getAttribute('data-destructive') === 'true';
            showConfirmModal(confirmMessage, form, isDestructive);
          });
        });
      })();
    </script>
  </body>
</html>

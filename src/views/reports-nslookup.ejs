<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/public/css/styles.css" />
  </head>
  <body class="bg-grid">
    <% if (toast && toast.text) { %>
      <aside class="toast toast-<%= toast.type || 'info' %>" id="app-toast" role="status" aria-live="polite">
        <div class="toast-title"><%= toast.type === 'error' ? 'Falha na execução' : 'Notificação' %></div>
        <div class="toast-text"><%= toast.text %></div>
        <button type="button" class="toast-close" id="toast-close" aria-label="Fechar notificação">x</button>
        <div class="toast-bar"></div>
      </aside>
    <% } %>

    <header class="topbar">
      <div>
        <h1>DNSBlock</h1>
        <p>Olá, <strong><%= user.fullName || user.username %></strong></p>
      </div>
      <div class="topbar-actions">
        <a href="/dashboard" class="btn-secondary">Dashboard</a>
        <a href="/domains/new" class="btn-secondary">Cadastrar Domínios</a>
        <a href="/reports/nslookup" class="btn-secondary">Relatórios</a>
        <a href="/dns/integration" class="btn-secondary">Integração DNS</a>
        <% if (user.isAdmin) { %>
          <a href="/users" class="btn-secondary">Usuários</a>
          <a href="/audit" class="btn-secondary">Auditoria</a>
        <% } %>
        <details class="user-dropdown">
          <summary class="user-dropdown-trigger">
            <span class="user-dropdown-text">@<%= user.username %></span>
            <span class="user-dropdown-caret" aria-hidden="true">▾</span>
          </summary>
          <div class="user-dropdown-menu">
            <a href="/account/password" class="user-dropdown-link">Trocar minha senha</a>
            <form method="post" action="/logout" class="user-dropdown-form">
              <button type="submit" class="user-dropdown-logout">Sair</button>
            </form>
          </div>
        </details>
      </div>
    </header>

    <main class="content-wrap">
      <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <section class="table-section">
        <div class="table-header">
          <h3>Relatório de Verificação (nslookup)</h3>
          <form method="post" action="/reports/nslookup/start">
            <button type="submit" class="btn-primary">Gerar Relatório Geral</button>
          </form>
        </div>

        <p class="helper-text report-version-note">
          Versão atual da blocklist: <strong><%= latestBlocklistVersion || 'sem versão' %></strong>.
          Só é permitido gerar novo relatório quando a versão mudar.
          <% if (latestGeneralReport) { %>
            Último relatório geral: versão <strong><%= latestGeneralReport.blocklist_version %></strong> com status <strong><%= latestGeneralReport.status %></strong>.
          <% } %>
        </p>

        <div class="table-container report-notice-table-wrap">
          <table>
            <thead>
              <tr>
                <th>Ofício</th>
                <th>Domínios Ativos</th>
                <th>Último Status</th>
                <th>Ação</th>
              </tr>
            </thead>
            <tbody>
              <% if (!noticeReports || noticeReports.length === 0) { %>
                <tr class="empty-row">
                  <td colspan="4">Nenhum ofício com domínio ativo disponível para geração de relatório.</td>
                </tr>
              <% } %>

              <% (noticeReports || []).forEach(function (noticeItem) { %>
                <tr>
                  <td><strong><%= noticeItem.notice_code %></strong></td>
                  <td><%= noticeItem.active_domains %></td>
                  <td>
                    <% if (noticeItem.latest_status) { %>
                      <span class="report-status-pill report-status-<%= noticeItem.latest_status %>"><%= noticeItem.latest_status %></span>
                    <% } else { %>
                      <span class="muted-inline">sem relatório</span>
                    <% } %>
                  </td>
                  <td>
                    <div class="report-row-actions">
                      <form method="post" action="/reports/nslookup/start">
                        <input type="hidden" name="noticeId" value="<%= noticeItem.id %>" />
                        <button type="submit" class="btn-secondary">Gerar relatório</button>
                      </form>
                      <% if (noticeItem.latest_status === 'completed' && noticeItem.latest_job_id) { %>
                        <a class="btn-secondary" href="/reports/nslookup/download?jobId=<%= encodeURIComponent(noticeItem.latest_job_id) %>">Baixar último</a>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div
          id="report-progress-panel"
          class="report-progress-panel"
          data-job-id="<%= reportJob ? reportJob.id : '' %>"
          data-job-status="<%= reportJob ? reportJob.status : 'idle' %>"
        >
          <div class="report-progress-meta">
            <strong id="report-status-label">Status: <%= reportJob ? reportJob.status : 'idle' %> <%= reportJob && reportJob.scopeLabel ? `(${reportJob.scopeLabel})` : '' %></strong>
            <span id="report-progress-label"><%= reportJob ? `${reportJob.progress}%` : '0%' %></span>
          </div>
          <div class="report-progress-track">
            <div id="report-progress-fill" class="report-progress-fill" style="width: <%= reportJob ? reportJob.progress : 0 %>%"></div>
          </div>
          <p class="helper-text" id="report-progress-helper">
            <% if (reportJob) { %>
              Processados: <%= reportJob.processed %> de <%= reportJob.total %> (<%= reportJob.scopeLabel || 'Geral' %>)
            <% } else { %>
              Clique em "Gerar Relatório Geral" ou use o botão por ofício para iniciar a verificação de nslookup em background.
            <% } %>
          </p>
          <a
            id="report-download-link"
            class="btn-secondary report-download-link <%= reportJob && reportJob.status === 'completed' ? '' : 'is-hidden' %>"
            href="/reports/nslookup/download<%= reportJob ? `?jobId=${reportJob.id}` : '' %>"
          >Baixar relatório PDF</a>
        </div>
      </section>
    </main>

    <% if (toast && toast.text) { %>
      <script>
        (function () {
          const toast = document.getElementById('app-toast');
          const closeBtn = document.getElementById('toast-close');

          if (!toast) return;

          function closeToast() {
            toast.classList.add('toast-out');
            window.setTimeout(() => toast.remove(), 300);
          }

          if (closeBtn) {
            closeBtn.addEventListener('click', closeToast);
          }

          window.setTimeout(closeToast, 4500);
        })();
      </script>
    <% } %>

    <script>
      (function () {
        const panel = document.getElementById('report-progress-panel');
        if (!panel) return;

        const statusLabel = document.getElementById('report-status-label');
        const percentLabel = document.getElementById('report-progress-label');
        const helperLabel = document.getElementById('report-progress-helper');
        const fill = document.getElementById('report-progress-fill');
        const downloadLink = document.getElementById('report-download-link');

        let jobId = panel.getAttribute('data-job-id') || '';
        let jobStatus = panel.getAttribute('data-job-status') || 'idle';

        function applyStatus(data) {
          const status = data.status || 'idle';
          const progress = Number(data.progress || 0);
          const processed = Number(data.processed || 0);
          const total = Number(data.total || 0);
          const scopeLabel = data.scopeLabel || 'Geral';

          jobStatus = status;

          if (statusLabel) statusLabel.textContent = `Status: ${status} (${scopeLabel})`;
          if (percentLabel) percentLabel.textContent = `${progress}%`;
          if (fill) fill.style.width = `${progress}%`;

          if (helperLabel) {
            if (status === 'failed') {
              helperLabel.textContent = data.error || 'Falha na execução do relatório.';
            } else if (status === 'idle') {
              helperLabel.textContent = 'Nenhum relatório em execução.';
            } else {
              helperLabel.textContent = `Processados: ${processed} de ${total} (${scopeLabel})`;
            }
          }

          if (downloadLink) {
            if (status === 'completed' && data.id) {
              downloadLink.classList.remove('is-hidden');
              downloadLink.href = `/reports/nslookup/download?jobId=${encodeURIComponent(data.id)}`;
            } else {
              downloadLink.classList.add('is-hidden');
            }
          }
        }

        async function pollStatus() {
          if (!jobId) return;

          try {
            const response = await fetch(`/reports/nslookup/status?jobId=${encodeURIComponent(jobId)}`, {
              method: 'GET',
              headers: { Accept: 'application/json' },
              credentials: 'same-origin',
            });

            if (!response.ok) return;
            const data = await response.json();
            applyStatus(data);

            if (data.status === 'running' || data.status === 'queued') {
              window.setTimeout(pollStatus, 2000);
            }
          } catch (error) {
            if (helperLabel) {
              helperLabel.textContent = 'Não foi possível atualizar o progresso neste momento.';
            }
          }
        }

        if (jobStatus === 'running' || jobStatus === 'queued' || jobStatus === 'completed' || jobStatus === 'failed') {
          pollStatus();
        }
      })();
    </script>
  </body>
</html>

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/public/css/styles.css" />
  </head>
  <body class="bg-grid">
    <% if (typeof toast !== 'undefined' && toast && toast.text) { %>
      <aside class="toast toast-<%= toast.type || 'info' %>" id="app-toast" role="status" aria-live="polite">
        <div class="toast-title"><%= toast.type === 'error' ? 'Falha no cadastro' : 'Notificação' %></div>
        <div class="toast-text"><%= toast.text %></div>
        <button type="button" class="toast-close" id="toast-close" aria-label="Fechar notificação">x</button>
        <div class="toast-bar"></div>
      </aside>
    <% } %>

    <header class="topbar">
      <div>
        <h1>Cadastrar Domínios</h1>
        <p>Insira um domínio por linha, no formato exemplo: bet.jogo.com</p>
      </div>
      <div class="topbar-actions">
        <a href="/dashboard" class="btn-secondary">Dashboard</a>
        <a href="/domains/new" class="btn-secondary">Cadastrar Domínios</a>
        <a href="/reports/nslookup" class="btn-secondary">Relatórios</a>
        <a href="/dns/integration" class="btn-secondary">Integração DNS</a>
        <% if (user.isAdmin) { %>
          <a href="/users" class="btn-secondary">Usuários</a>
        <% } %>
        <details class="user-dropdown">
          <summary class="user-dropdown-trigger">
            <span class="user-dropdown-text">@<%= user.username %></span>
            <span class="user-dropdown-caret" aria-hidden="true">▾</span>
          </summary>
          <div class="user-dropdown-menu">
            <a href="/account/password" class="user-dropdown-link">Trocar minha senha</a>
            <form method="post" action="/logout" class="user-dropdown-form">
              <button type="submit" class="user-dropdown-logout">Sair</button>
            </form>
          </div>
        </details>
      </div>
    </header>

    <main class="content-wrap">
      <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <section class="form-panel">
        <form method="post" action="/domains" class="form-stack" enctype="multipart/form-data">
          <label for="domains">Lista de Domínios</label>
          <textarea id="domains" name="domains" rows="10" placeholder="bet.jogo.com&#10;site-aposta.net"><%= inputDomains %></textarea>
          <p class="helper-text">O sistema remove espaços, vírgulas, acentos e caracteres especiais automaticamente e salva em minúsculo.</p>

          <div class="date-grid">
            <div>
              <label for="blockStartDate">Data Inicial de Bloqueio (opcional)</label>
              <input id="blockStartDate" name="blockStartDate" type="date" value="<%= inputBlockStartDate || '' %>" />
            </div>
            <div>
              <label for="blockEndDate">Data Final de Bloqueio (opcional)</label>
              <input id="blockEndDate" name="blockEndDate" type="date" value="<%= inputBlockEndDate || '' %>" />
            </div>
          </div>

          <label for="noticeCode">Identificação do Ofício (opcional)</label>
          <input id="noticeCode" name="noticeCode" type="text" placeholder="Ex.: Ofício 123/2026" value="<%= inputNoticeCode || '' %>" />

          <label for="officialFiles">Anexos do Ofício (opcional)</label>
          <input id="officialFiles" name="officialFiles" type="file" multiple />
          <p class="helper-text">Você pode anexar vários arquivos (PDF, PNG, CSV ou outro formato).</p>

          <button type="submit" class="btn-primary">Salvar Domínios</button>
        </form>
      </section>

      <section class="table-section">
        <div class="table-header">
          <h3>Domínios inválidos para revisão</h3>
        </div>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Valor enviado</th>
                <th>Valor normalizado</th>
                <th>Motivo</th>
                <th>Data</th>
              </tr>
            </thead>
            <tbody>
              <% if (!invalidDomainsReview || invalidDomainsReview.length === 0) { %>
                <tr>
                  <td colspan="4">Nenhum domínio inválido registrado para revisão.</td>
                </tr>
              <% } %>
              <% if (invalidDomainsReview && invalidDomainsReview.length > 0) { %>
                <% invalidDomainsReview.forEach(function (row) { %>
                  <tr>
                    <td><%= row.original_value %></td>
                    <td><%= row.normalized_value || '-' %></td>
                    <td><%= row.reason %></td>
                    <td><%= new Date(row.created_at).toLocaleString('pt-BR') %></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </section>
    </main>

    <% if (typeof toast !== 'undefined' && toast && toast.text) { %>
      <script>
        (function () {
          const toast = document.getElementById('app-toast');
          const closeBtn = document.getElementById('toast-close');

          if (!toast) return;

          function closeToast() {
            toast.classList.add('toast-out');
            window.setTimeout(() => toast.remove(), 300);
          }

          if (closeBtn) {
            closeBtn.addEventListener('click', closeToast);
          }

          window.setTimeout(closeToast, 4500);
        })();
      </script>
    <% } %>
  </body>
</html>

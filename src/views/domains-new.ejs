<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/public/css/styles.css" />
  </head>
  <body class="app-layout bg-grid">
    <%- include('partials/sidebar', { activePage: 'notices' }) %>
    <div class="main-content">
      <%- include('partials/topbar', { pageTitle: 'Cadastrar Ofício', pageSubtitle: 'Insira as informações do novo ofício' }) %>

      <main class="content-wrap">
      <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <section class="form-panel">
        <form method="post" action="/notices" class="form-stack">
          <label for="noticeCode">Número do Ofício</label>
          <input id="noticeCode" name="noticeCode" type="text" placeholder="Ex.: Ofício 123/2026" value="<%= inputNoticeCode || '' %>" required />
          <label for="noticeName">Nome do Ofício</label>
          <input id="noticeName" name="noticeName" type="text" placeholder="Nome do ofício" required />
          <button type="submit" class="btn-primary">Salvar Ofício</button>
        </form>
      </section>

      <section class="table-section">
        <div class="table-header">
          <h3>Domínios inválidos para revisão</h3>
        </div>

        <form method="get" action="/domains/new" class="table-controls" style="display:flex;gap:12px;align-items:center;margin-bottom:12px;">
          <input type="text" name="search" value="<%= invalidDomainsReview.search || '' %>" placeholder="Buscar..." style="flex:2;min-width:220px;max-width:400px;padding:8px 12px;font-size:1rem;" />
          <label for="pageSize" style="margin:0 4px 0 12px;">Itens:</label>
          <select name="pageSize" id="pageSize" onchange="this.form.submit()" style="width:60px;padding:4px 6px;font-size:0.98rem;">
            <option value="5" <%= invalidDomainsReview.pageSize == 5 ? 'selected' : '' %>>5</option>
            <option value="10" <%= invalidDomainsReview.pageSize == 10 ? 'selected' : '' %>>10</option>
            <option value="20" <%= invalidDomainsReview.pageSize == 20 ? 'selected' : '' %>>20</option>
            <option value="50" <%= invalidDomainsReview.pageSize == 50 ? 'selected' : '' %>>50</option>
            <option value="100" <%= invalidDomainsReview.pageSize == 100 ? 'selected' : '' %>>100</option>
          </select>
          <button type="submit" class="btn-secondary">Buscar</button>
        </form>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Valor enviado</th>
                <th>Valor normalizado</th>
                <th>Motivo</th>
                <th>Data</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              <% if (!invalidDomainsReview.rows || invalidDomainsReview.rows.length === 0) { %>
                <tr>
                  <td colspan="4">Nenhum domínio inválido registrado para revisão.</td>
                </tr>
              <% } %>
              <% if (invalidDomainsReview.rows && invalidDomainsReview.rows.length > 0) { %>
                <% invalidDomainsReview.rows.forEach(function (row, idx) { %>
                  <tr>
                    <td><%= row.original_value %></td>
                    <td><%= row.normalized_value || '-' %></td>
                    <td><%= row.reason %></td>
                    <td><%= new Date(row.created_at).toLocaleString('pt-BR') %></td>
                    <td>
                      <form method="post" action="/domains/invalids/delete" style="display:inline;" onsubmit="return confirm('Excluir este domínio inválido?');">
                        <input type="hidden" name="original_value" value="<%= row.original_value %>" />
                        <button type="submit" class="btn-danger" title="Excluir">🗑️</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>

        <form method="post" action="/domains/invalids/delete-all" onsubmit="return confirm('Remover todos os domínios inválidos?');" style="margin: 16px 0 0 0; text-align:right;">
          <button type="submit" class="btn-danger">Remover todos</button>
        </form>

        <div class="pagination-controls" style="display:flex;align-items:center;gap:10px;margin-top:10px;justify-content:center;">
          <% if (invalidDomainsReview.page > 1) { %>
            <a href="?page=<%= invalidDomainsReview.page - 1 %>&pageSize=<%= invalidDomainsReview.pageSize %>&search=<%= encodeURIComponent(invalidDomainsReview.search || '') %>" class="btn-secondary">Anterior</a>
          <% } else { %>
            <span class="btn-secondary" style="opacity:0.5;pointer-events:none;">Anterior</span>
          <% } %>
          <span>Página <%= invalidDomainsReview.page %> de <%= invalidDomainsReview.totalPages %></span>
          <% if (invalidDomainsReview.page < invalidDomainsReview.totalPages) { %>
            <a href="?page=<%= invalidDomainsReview.page + 1 %>&pageSize=<%= invalidDomainsReview.pageSize %>&search=<%= encodeURIComponent(invalidDomainsReview.search || '') %>" class="btn-secondary">Próxima</a>
          <% } else { %>
            <span class="btn-secondary" style="opacity:0.5;pointer-events:none;">Próxima</span>
          <% } %>
          <span style="margin-left:16px;">Total: <%= invalidDomainsReview.total %></span>
        </div>
      </section>
    </main>

    <% if (typeof toast !== 'undefined' && toast && toast.text) { %>
      <script>
        (function () {
          const toast = document.getElementById('app-toast');
          const closeBtn = document.getElementById('toast-close');

          if (!toast) return;

          function closeToast() {
            toast.classList.add('toast-out');
            window.setTimeout(() => toast.remove(), 300);
          }

          if (closeBtn) {
            closeBtn.addEventListener('click', closeToast);
          }

          window.setTimeout(closeToast, 4500);
        })();
      </script>
    <% } %>
    </div> <!-- .main-content -->
  </body>
</html>

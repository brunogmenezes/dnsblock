<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/public/css/styles.css" />
  </head>
  <body class="app-layout bg-grid">
    <%- include('partials/sidebar', { activePage: 'users' }) %>
    <div class="main-content">
      <%- include('partials/topbar', { pageTitle: 'Editar Usuário', pageSubtitle: `Ajuste dados e permissões de ${targetUser.username}` }) %>

      <main class="content-wrap narrow-wrap">
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <section class="form-panel user-create-panel">
        <form method="post" action="/users/<%= targetUser.id %>/edit" class="form-stack">
          <label for="fullName">Nome completo</label>
          <input id="fullName" name="fullName" type="text" value="<%= formData.fullName || '' %>" required />

          <label for="username">Usuário</label>
          <input id="username" name="username" type="text" value="<%= formData.username || '' %>" required />

          <label for="newPassword">Nova senha (opcional)</label>
          <input id="newPassword" name="newPassword" type="password" autocomplete="new-password" />
          <p class="helper-text">Se preencher, a senha será atualizada.</p>

          <label class="check-row user-check-row">
            <input name="isAdmin" type="checkbox" <%= formData.isAdmin ? 'checked' : '' %> />
            <span>Usuário administrador</span>
          </label>

          <label class="check-row user-check-row">
            <input name="isActive" type="checkbox" <%= formData.isActive ? 'checked' : '' %> />
            <span>Usuário ativo</span>
          </label>

          <label class="check-row user-check-row">
            <input name="mustChangePassword" type="checkbox" <%= formData.mustChangePassword ? 'checked' : '' %> />
            <span>Exigir troca de senha no próximo login</span>
          </label>

          <div class="user-submit-wrap">
            <button type="submit" class="btn-primary">Salvar alterações</button>
          </div>
        </form>
      </section>
    </main>

    <% if (toast && toast.text) { %>
      <script>
        (function () {
          const toast = document.getElementById('app-toast');
          const closeBtn = document.getElementById('toast-close');

          if (!toast) return;

          function closeToast() {
            toast.classList.add('toast-out');
            window.setTimeout(() => toast.remove(), 300);
          }

          if (closeBtn) {
            closeBtn.addEventListener('click', closeToast);
          }

          window.setTimeout(closeToast, 4500);
        })();
      </script>
    <% } %>
    </div> <!-- .main-content -->
  </body>
</html>

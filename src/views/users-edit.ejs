<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/public/css/styles.css" />
  </head>
  <body class="bg-grid">
    <% if (toast && toast.text) { %>
      <aside class="toast toast-<%= toast.type || 'info' %>" id="app-toast" role="status" aria-live="polite">
        <div class="toast-title"><%= toast.type === 'error' ? 'Falha na execução' : 'Notificação' %></div>
        <div class="toast-text"><%= toast.text %></div>
        <button type="button" class="toast-close" id="toast-close" aria-label="Fechar notificação">x</button>
        <div class="toast-bar"></div>
      </aside>
    <% } %>

    <header class="topbar">
      <div>
        <h1>Editar Usuário</h1>
        <p>Ajuste dados e permissões de <strong><%= targetUser.username %></strong>.</p>
      </div>
      <div class="topbar-actions">
        <a href="/dashboard" class="btn-secondary">Dashboard</a>
        <a href="/domains/new" class="btn-secondary">Cadastrar Domínios</a>
        <a href="/reports/nslookup" class="btn-secondary">Relatórios</a>
        <a href="/dns/integration" class="btn-secondary">Integração DNS</a>
        <% if (user.isAdmin) { %>
          <a href="/users" class="btn-secondary">Usuários</a>
        <% } %>
        <details class="user-dropdown">
          <summary class="user-dropdown-trigger">
            <span class="user-dropdown-text">@<%= user.username %></span>
            <span class="user-dropdown-caret" aria-hidden="true">▾</span>
          </summary>
          <div class="user-dropdown-menu">
            <a href="/account/password" class="user-dropdown-link">Trocar minha senha</a>
            <form method="post" action="/logout" class="user-dropdown-form">
              <button type="submit" class="user-dropdown-logout">Sair</button>
            </form>
          </div>
        </details>
      </div>
    </header>

    <main class="content-wrap narrow-wrap">
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <section class="form-panel user-create-panel">
        <form method="post" action="/users/<%= targetUser.id %>/edit" class="form-stack">
          <label for="fullName">Nome completo</label>
          <input id="fullName" name="fullName" type="text" value="<%= formData.fullName || '' %>" required />

          <label for="username">Usuário</label>
          <input id="username" name="username" type="text" value="<%= formData.username || '' %>" required />

          <label for="newPassword">Nova senha (opcional)</label>
          <input id="newPassword" name="newPassword" type="password" autocomplete="new-password" />
          <p class="helper-text">Se preencher, a senha será atualizada.</p>

          <label class="check-row user-check-row">
            <input name="isAdmin" type="checkbox" <%= formData.isAdmin ? 'checked' : '' %> />
            <span>Usuário administrador</span>
          </label>

          <label class="check-row user-check-row">
            <input name="isActive" type="checkbox" <%= formData.isActive ? 'checked' : '' %> />
            <span>Usuário ativo</span>
          </label>

          <label class="check-row user-check-row">
            <input name="mustChangePassword" type="checkbox" <%= formData.mustChangePassword ? 'checked' : '' %> />
            <span>Exigir troca de senha no próximo login</span>
          </label>

          <div class="user-submit-wrap">
            <button type="submit" class="btn-primary">Salvar alterações</button>
          </div>
        </form>
      </section>
    </main>

    <% if (toast && toast.text) { %>
      <script>
        (function () {
          const toast = document.getElementById('app-toast');
          const closeBtn = document.getElementById('toast-close');

          if (!toast) return;

          function closeToast() {
            toast.classList.add('toast-out');
            window.setTimeout(() => toast.remove(), 300);
          }

          if (closeBtn) {
            closeBtn.addEventListener('click', closeToast);
          }

          window.setTimeout(closeToast, 4500);
        })();
      </script>
    <% } %>
  </body>
</html>

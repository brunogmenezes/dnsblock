<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/public/css/styles.css" />
  </head>
  <body class="bg-grid">
    <% if (toast && toast.text) { %>
      <aside class="toast toast-<%= toast.type || 'info' %>" id="app-toast" role="status" aria-live="polite">
        <div class="toast-title"><%= toast.type === 'error' ? 'Falha na execução' : 'Notificação' %></div>
        <div class="toast-text"><%= toast.text %></div>
        <button type="button" class="toast-close" id="toast-close" aria-label="Fechar notificação">x</button>
        <div class="toast-bar"></div>
      </aside>
    <% } %>

    <header class="topbar">
      <div>
        <h1>Auditoria do Sistema</h1>
        <p>Rastreio de login, IP e ações executadas pelos usuários.</p>
      </div>
      <div class="topbar-actions">
        <a href="/dashboard" class="btn-secondary">Dashboard</a>
        <a href="/domains/new" class="btn-secondary">Cadastrar Domínios</a>
        <a href="/reports/nslookup" class="btn-secondary">Relatórios</a>
        <a href="/dns/integration" class="btn-secondary">Integração DNS</a>
        <% if (user.isAdmin) { %>
          <a href="/users" class="btn-secondary">Usuários</a>
          <a href="/audit" class="btn-secondary">Auditoria</a>
        <% } %>
        <details class="user-dropdown">
          <summary class="user-dropdown-trigger">
            <span class="user-dropdown-text">@<%= user.username %></span>
            <span class="user-dropdown-caret" aria-hidden="true">▾</span>
          </summary>
          <div class="user-dropdown-menu">
            <a href="/account/password" class="user-dropdown-link">Trocar minha senha</a>
            <form method="post" action="/logout" class="user-dropdown-form">
              <button type="submit" class="user-dropdown-logout">Sair</button>
            </form>
          </div>
        </details>
      </div>
    </header>

    <main class="content-wrap">
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <section class="table-section">
        <div class="table-header">
          <h3>Eventos de auditoria</h3>
          <span class="helper-text"><strong><%= total %></strong> registros encontrados</span>
        </div>

        <form method="get" action="/audit" class="table-controls">
          <input
            id="audit-query"
            name="q"
            type="text"
            placeholder="Buscar por usuário, ação, IP ou detalhe"
            value="<%= query || '' %>"
          />
          <select name="limit" aria-label="Registros por página">
            <option value="10" <%= pageSize === 10 ? 'selected' : '' %>>10</option>
            <option value="20" <%= pageSize === 20 ? 'selected' : '' %>>20</option>
            <option value="50" <%= pageSize === 50 ? 'selected' : '' %>>50</option>
            <option value="100" <%= pageSize === 100 ? 'selected' : '' %>>100</option>
          </select>
          <button type="submit" class="btn-primary">Buscar</button>
        </form>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Data/Hora</th>
                <th>Usuário</th>
                <th>Ação</th>
                <th>IP</th>
                <th>Detalhes</th>
              </tr>
            </thead>
            <tbody>
              <% if (!logs || logs.length === 0) { %>
                <tr>
                  <td colspan="5">Nenhum registro de auditoria encontrado para os filtros aplicados.</td>
                </tr>
              <% } %>

              <% if (logs && logs.length > 0) { %>
                <% logs.forEach(function (row) { %>
                  <% const displayUser = row.actor_full_name || row.actor_username || row.username_snapshot || 'Sistema'; %>
                  <tr>
                    <td><%= new Date(row.created_at).toLocaleString('pt-BR') %></td>
                    <td><%= displayUser %></td>
                    <td><%= row.action %></td>
                    <td><%= row.ip_address || '-' %></td>
                    <td class="cell-wrap"><%= row.details ? JSON.stringify(row.details) : '-' %></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>

        <% const previousPage = currentPage > 1 ? currentPage - 1 : 1; %>
        <% const nextPage = currentPage < totalPages ? currentPage + 1 : totalPages; %>

        <div class="table-pagination">
          <a href="/audit?page=<%= previousPage %>&limit=<%= pageSize %>&q=<%= encodeURIComponent(query || '') %>" class="btn-secondary <%= currentPage <= 1 ? 'is-disabled-link' : '' %>">Anterior</a>
          <span>Página <%= currentPage %> de <%= totalPages %></span>
          <a href="/audit?page=<%= nextPage %>&limit=<%= pageSize %>&q=<%= encodeURIComponent(query || '') %>" class="btn-secondary <%= currentPage >= totalPages ? 'is-disabled-link' : '' %>">Próxima</a>
        </div>
      </section>
    </main>

    <% if (toast && toast.text) { %>
      <script>
        (function () {
          const toast = document.getElementById('app-toast');
          const closeBtn = document.getElementById('toast-close');

          if (!toast) return;

          function closeToast() {
            toast.classList.add('toast-out');
            window.setTimeout(() => toast.remove(), 300);
          }

          if (closeBtn) {
            closeBtn.addEventListener('click', closeToast);
          }

          window.setTimeout(closeToast, 4500);
        })();
      </script>
    <% } %>
  </body>
</html>

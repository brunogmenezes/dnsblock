<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/public/css/styles.css" />
  </head>
  <body class="bg-grid">
    <main class="centered-container">
      <section class="auth-card">
        <div class="brand-logo" style="justify-content: center; margin-bottom: 24px;">
          <div class="brand-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <h2 style="color: var(--text);">DNSBlock</h2>
        </div>
        
        <p class="subtitle" style="text-align: center; color: var(--muted); margin-top: -12px; margin-bottom: 32px; font-weight: 500;">Gestão de domínios para bloqueio<br>por ofícios da Anatel</p>

        <% if (error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>

        <form method="post" action="/login" class="form-stack">
          <div style="margin-bottom: 4px;">
            <label for="username">Usuário</label>
            <input id="username" name="username" type="text" placeholder="Seu nome de usuário" required autofocus />
          </div>

          <div style="margin-bottom: 8px;">
            <label for="password">Senha</label>
            <input id="password" name="password" type="password" placeholder="Sua senha de acesso" required />
          </div>

          <button type="submit" class="btn-primary" style="margin-top: 8px; padding: 12px; font-size: 1rem;">Entrar no Sistema</button>
        </form>
      </section>
    </main>
  </body>
</html>
